# Copy this file to ".env" locally, and set the same keys in
# Railway's dashboard under Variables for your deployed backend service.

# Postgres connection string from Neon (Dashboard -> your project -> Connection string)
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require

# A long random string used to sign login sessions. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Gmail address you'll send verification emails from
GMAIL_USER=youraddress@gmail.com
# 16-character App Password (NOT your Gmail login password) — see README
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# The public URL of THIS backend once deployed on Railway, e.g.
# https://plant-shop-auth-production.up.railway.app
BACKEND_URL=http://localhost:3000

# The public URL of your existing static frontend on Railway, e.g.
# https://plant-shop.up.railway.app
FRONTEND_URL=http://localhost:5500

PORT=3000
